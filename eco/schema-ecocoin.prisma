// ----- NOVOS ENUMS -----

enum Level {
  SEMENTE   // 0 – 100 coins
  BROTO     // 101 – 500 coins
  ARVORE    // 501 – 2.000 coins
  GUARDIAO  // 2.001+ coins
}

enum CoinEvent {
  SIGNUP            // +20 — cadastro completo (único)
  ARTICLE_READ      // +2  — artigo lido até o final
  REPORT_SUBMITTED  // +5  — reporte de problema enviado
  STREAK_7_DAYS     // +15 — 7 dias consecutivos de acesso
  REFERRAL          // +20 — indicação de amigo que se cadastrou
  MISSION_COMPLETE  // variável — missão diária/semanal concluída
  BADGE_EARNED      // variável — conquista desbloqueada
  REDEMPTION        // negativo — resgate de recompensa
  ADMIN_GRANT       // variável — concessão manual pelo admin
}

enum MissionType {
  DAILY   // reseta à meia-noite
  WEEKLY  // reseta toda segunda-feira
}

// ----- NOVOS MODELOS -----

model Wallet {
  id           String            @id @default(cuid())
  userId       String            @unique
  balance      Int               @default(0)   // saldo atual (nunca negativo)
  totalEarned  Int               @default(0)   // lifetime — para rankings
  level        Level             @default(SEMENTE)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions CoinTransaction[]
}

model CoinTransaction {
  id        String     @id @default(cuid())
  walletId  String
  amount    Int        // positivo = ganhou, negativo = gastou
  event     CoinEvent
  reference String?    // ID do artigo lido, do amigo indicado, etc.
  note      String?    // descrição legível para o histórico
  createdAt DateTime   @default(now())
  wallet    Wallet     @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Badge {
  id          String      @id @default(cuid())
  slug        String      @unique  // ex: "primeiro-descarte", "leitor-assiduo"
  name        String      // ex: "Primeiro Descarte"
  description String      // ex: "Registrou seu primeiro descarte de medicamento"
  iconUrl     String?     // URL no R2
  coinReward  Int         @default(0)
  active      Boolean     @default(true)
  userBadges  UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
}

model Mission {
  id           String        @id @default(cuid())
  slug         String        @unique  // ex: "ler-3-artigos"
  title        String        // ex: "Leitor do dia"
  description  String        // ex: "Leia 3 artigos hoje"
  type         MissionType
  event        CoinEvent     // qual ação conta para progresso
  targetCount  Int           @default(1)  // quantas vezes executar
  coinReward   Int           // coins ao completar
  active       Boolean       @default(true)
  userMissions UserMission[]
}

model UserMission {
  id          String    @id @default(cuid())
  userId      String
  missionId   String
  progress    Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  expiresAt   DateTime  // DAILY: meia-noite; WEEKLY: próxima segunda
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission     Mission   @relation(fields: [missionId], references: [id])

  @@unique([userId, missionId, expiresAt])
}

