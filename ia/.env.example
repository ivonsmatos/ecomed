# ── Banco de dados (mesmo da aplicação Next.js — Supabase) ───────────────────
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# ── Groq — LLM de inferência ──────────────────────────────────────────────────
# Gere em: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo padrão (opções: llama-3.1-8b-instant | meta-llama/llama-4-scout-17b-16e-instruct)
GROQ_MODEL=llama-3.1-8b-instant

# ── Token de autenticação interno ─────────────────────────────────────────────
# Deve ser o mesmo valor de IA_SERVICE_TOKEN no .env da aplicação Next.js
# Gerado com: openssl rand -hex 32
IA_SERVICE_TOKEN=coloque-um-token-secreto-aqui
