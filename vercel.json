{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.ecomed.eco.br" }],
      "destination": "https://ecomed.eco.br/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/reset-missoes",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/sync-pontos",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/ensure-missoes",
      "schedule": "15 3 * * *"
    }
  ]
}
